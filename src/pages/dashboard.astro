---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Dashboard — The Grace Network"
  description="Your Grace Network member dashboard. View your activity, chat history, and workstream involvement."
>
  <Nav currentPath="/dashboard" />

  <main class="dashboard-main">
    <!-- Auth Gate -->
    <div class="dashboard-auth" id="dashboardAuth">
      <div class="auth-card">
        <div class="auth-constellation">
          <svg width="48" height="48" viewBox="0 0 120 120" fill="none">
            <line x1="60" y1="60" x2="60" y2="25" stroke="#3730A3" stroke-width="2" opacity="0.4"/>
            <line x1="60" y1="60" x2="90" y2="42" stroke="#3730A3" stroke-width="2" opacity="0.4"/>
            <line x1="60" y1="60" x2="90" y2="78" stroke="#3730A3" stroke-width="2" opacity="0.4"/>
            <line x1="60" y1="60" x2="60" y2="95" stroke="#B45309" stroke-width="2" opacity="0.35"/>
            <line x1="60" y1="60" x2="30" y2="78" stroke="#B45309" stroke-width="2" opacity="0.35"/>
            <line x1="60" y1="60" x2="30" y2="42" stroke="#3730A3" stroke-width="2" opacity="0.4"/>
            <circle cx="60" cy="25" r="5" fill="#3730A3"/>
            <circle cx="90" cy="42" r="5" fill="#3730A3"/>
            <circle cx="90" cy="78" r="5" fill="#6366F1"/>
            <circle cx="60" cy="95" r="5" fill="#B45309"/>
            <circle cx="30" cy="78" r="5" fill="#B45309"/>
            <circle cx="30" cy="42" r="5" fill="#6366F1"/>
            <circle cx="60" cy="60" r="10" fill="#3730A3"/>
          </svg>
        </div>
        <h1>Member Dashboard</h1>
        <p class="auth-subtitle">Enter the email you signed up with to access your dashboard.</p>
        <div class="form-group">
          <input type="email" id="dashboardEmail" placeholder="your@email.com" autocomplete="email" />
        </div>
        <button class="btn-grace btn-full" id="dashboardLogin">Access Dashboard</button>
        <p class="auth-error" id="authError"></p>
        <p class="auth-hint">Not a member yet? <a href="/#sign">Join the Network</a></p>
      </div>
    </div>

    <!-- Dashboard Content (hidden until authenticated) -->
    <div class="dashboard-content" id="dashboardContent" style="display: none;">
      <!-- Header -->
      <div class="dash-header">
        <div class="section-inner">
          <div class="dash-header-inner">
            <div>
              <span class="section-tag">Member Dashboard</span>
              <h1 class="dash-greeting" id="dashGreeting">Welcome back</h1>
              <p class="dash-joined" id="dashJoined"></p>
            </div>
            <button class="btn-ghost-grace dash-logout" id="dashLogout">Sign Out</button>
          </div>
        </div>
      </div>

      <!-- Stats Row -->
      <section class="dash-stats">
        <div class="section-inner">
          <div class="stats-grid">
            <div class="stat-card">
              <span class="stat-number" id="statMessages">0</span>
              <span class="stat-label">Messages Sent</span>
            </div>
            <div class="stat-card">
              <span class="stat-number" id="statSessions">0</span>
              <span class="stat-label">Chat Sessions</span>
            </div>
            <div class="stat-card">
              <span class="stat-number" id="statNetwork">0</span>
              <span class="stat-label">Network Members</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Two-Column Layout -->
      <section class="dash-body">
        <div class="section-inner">
          <div class="dash-grid">
            <!-- Left: Activity Feed -->
            <div class="dash-panel">
              <h2 class="dash-panel-title">Recent Activity</h2>
              <div class="activity-feed" id="activityFeed">
                <p class="empty-state">No activity yet. Start by chatting with GRACE.</p>
              </div>
            </div>

            <!-- Right: Member Profile + Quick Actions -->
            <div class="dash-sidebar">
              <!-- Profile Card -->
              <div class="profile-card">
                <h2 class="dash-panel-title">Your Profile</h2>
                <div class="profile-fields">
                  <div class="profile-field">
                    <span class="profile-label">Name</span>
                    <span class="profile-value" id="profileName">—</span>
                  </div>
                  <div class="profile-field">
                    <span class="profile-label">Email</span>
                    <span class="profile-value" id="profileEmail">—</span>
                  </div>
                  <div class="profile-field">
                    <span class="profile-label">Statement</span>
                    <span class="profile-value profile-statement" id="profileStatement">—</span>
                  </div>
                </div>
              </div>

              <!-- Quick Actions -->
              <div class="actions-card">
                <h2 class="dash-panel-title">Quick Actions</h2>
                <div class="quick-actions">
                  <a href="/build" class="quick-action">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    <span>Find a Workstream</span>
                  </a>
                  <a href="/constitution" class="quick-action">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    <span>Read the Constitution</span>
                  </a>
                  <a href="/toolkit" class="quick-action">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                    <span>Campaign Toolkit</span>
                  </a>
                  <button class="quick-action" id="openGraceChat">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    <span>Talk to GRACE</span>
                  </button>
                </div>
              </div>

              <!-- Chat History -->
              <div class="history-card">
                <h2 class="dash-panel-title">Chat History</h2>
                <div class="chat-history" id="chatHistory">
                  <p class="empty-state">No conversations yet.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const authSection = document.getElementById('dashboardAuth');
  const contentSection = document.getElementById('dashboardContent');
  const emailInput = document.getElementById('dashboardEmail') as HTMLInputElement;
  const loginBtn = document.getElementById('dashboardLogin');
  const authError = document.getElementById('authError');
  const logoutBtn = document.getElementById('dashLogout');

  // Check if already authenticated
  const storedEmail = localStorage.getItem('grace-member-email');
  if (storedEmail) {
    loadDashboard(storedEmail);
  }

  loginBtn?.addEventListener('click', () => {
    const email = emailInput?.value.trim();
    if (!email) {
      showError('Please enter your email.');
      return;
    }
    loadDashboard(email);
  });

  emailInput?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter') loginBtn?.click();
  });

  logoutBtn?.addEventListener('click', () => {
    localStorage.removeItem('grace-member-email');
    if (authSection) authSection.style.display = '';
    if (contentSection) contentSection.style.display = 'none';
  });

  document.getElementById('openGraceChat')?.addEventListener('click', () => {
    window.dispatchEvent(new Event('grace-open-chat'));
  });

  function showError(msg: string) {
    if (authError) {
      authError.textContent = msg;
      authError.style.display = 'block';
    }
  }

  async function loadDashboard(email: string) {
    try {
      const res = await fetch(`/api/members/dashboard?email=${encodeURIComponent(email)}`);
      if (!res.ok) {
        if (res.status === 404) {
          showError('No member found with that email. Have you joined yet?');
        } else {
          showError('Something went wrong. Please try again.');
        }
        return;
      }

      const data = await res.json();

      // Store email for persistence
      localStorage.setItem('grace-member-email', email);

      // Show dashboard
      if (authSection) authSection.style.display = 'none';
      if (contentSection) contentSection.style.display = '';

      // Populate header
      const greeting = document.getElementById('dashGreeting');
      if (greeting) greeting.textContent = `Welcome back, ${data.member.firstName}`;

      const joined = document.getElementById('dashJoined');
      if (joined) {
        const date = new Date(data.member.joinedAt);
        joined.textContent = `Member since ${date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}`;
      }

      // Populate stats
      const statMessages = document.getElementById('statMessages');
      const statSessions = document.getElementById('statSessions');
      const statNetwork = document.getElementById('statNetwork');
      if (statMessages) statMessages.textContent = data.stats.totalMessages.toLocaleString();
      if (statSessions) statSessions.textContent = data.stats.chatSessions.toLocaleString();
      if (statNetwork) statNetwork.textContent = data.stats.networkSize.toLocaleString();

      // Populate profile
      const profileName = document.getElementById('profileName');
      const profileEmail = document.getElementById('profileEmail');
      const profileStatement = document.getElementById('profileStatement');
      if (profileName) profileName.textContent = `${data.member.firstName} ${data.member.lastName}`;
      if (profileEmail) profileEmail.textContent = data.member.email;
      if (profileStatement) profileStatement.textContent = data.member.statement || 'No statement yet.';

      // Populate activity feed
      const activityFeed = document.getElementById('activityFeed');
      if (activityFeed && data.recentActivity?.length) {
        activityFeed.innerHTML = '';
        data.recentActivity.forEach((item: any) => {
          const el = document.createElement('div');
          el.className = 'activity-item';
          const date = new Date(item.created_at);
          const typeLabel = item.interaction_type === 'chat' ? 'Chat session'
            : item.interaction_type === 'signup' ? 'Joined the network'
            : item.interaction_type === 'workstream_join' ? 'Joined a workstream'
            : item.interaction_type;
          el.innerHTML = `
            <div class="activity-icon activity-icon-${item.interaction_type}"></div>
            <div class="activity-detail">
              <span class="activity-type">${typeLabel}</span>
              <span class="activity-time">${formatRelativeTime(date)}</span>
            </div>
          `;
          activityFeed.appendChild(el);
        });
      }

      // Populate chat history
      const chatHistory = document.getElementById('chatHistory');
      if (chatHistory && data.conversations?.length) {
        chatHistory.innerHTML = '';
        data.conversations.forEach((conv: any) => {
          const el = document.createElement('div');
          el.className = 'history-item';
          const date = new Date(conv.updatedAt);
          el.innerHTML = `
            <div class="history-meta">
              <span class="history-date">${date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
              <span class="history-count">${conv.messageCount} messages</span>
            </div>
            ${conv.summary ? `<p class="history-summary">${conv.summary}</p>` : ''}
          `;
          chatHistory.appendChild(el);
        });
      }

    } catch (err) {
      showError('Could not connect. Please try again.');
    }
  }

  function formatRelativeTime(date: Date): string {
    const now = new Date();
    const diff = now.getTime() - date.getTime();
    const minutes = Math.floor(diff / 60000);
    const hours = Math.floor(diff / 3600000);
    const days = Math.floor(diff / 86400000);

    if (minutes < 1) return 'Just now';
    if (minutes < 60) return `${minutes}m ago`;
    if (hours < 24) return `${hours}h ago`;
    if (days < 7) return `${days}d ago`;
    return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }
</script>

<style>
  /* Auth Gate */
  .dashboard-main {
    padding-top: 64px;
    min-height: 100vh;
  }

  .dashboard-auth {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 64px);
    padding: 2rem;
  }

  .auth-card {
    max-width: 420px;
    width: 100%;
    text-align: center;
  }

  .auth-constellation {
    margin-bottom: 1.5rem;
  }

  .auth-card h1 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--grace-text);
  }

  .auth-subtitle {
    color: var(--grace-text-secondary);
    font-size: 0.95rem;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .auth-card .form-group {
    margin-bottom: 1rem;
  }

  .auth-card .form-group input {
    width: 100%;
    padding: 0.875rem 1rem;
    background: var(--grace-surface);
    border: 1px solid var(--grace-border);
    border-radius: 8px;
    font-size: 1rem;
    font-family: var(--font-body);
    color: var(--grace-text);
    text-align: center;
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .auth-card .form-group input:focus {
    outline: none;
    border-color: var(--grace-purple);
    box-shadow: 0 0 0 3px rgba(55, 48, 163, 0.1);
  }

  .auth-card .form-group input::placeholder {
    color: var(--grace-text-muted);
  }

  .auth-error {
    display: none;
    color: #DC2626;
    font-size: 0.85rem;
    margin-top: 0.75rem;
  }

  .auth-hint {
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: var(--grace-text-muted);
  }

  .auth-hint a {
    color: var(--grace-purple);
    text-decoration: none;
    font-weight: 500;
  }

  .auth-hint a:hover {
    text-decoration: underline;
  }

  /* Dashboard Header */
  .dash-header {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--grace-border);
  }

  .dash-header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .dash-greeting {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--grace-text);
    margin-top: 0.5rem;
  }

  .dash-joined {
    color: var(--grace-text-muted);
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }

  .dash-logout {
    padding: 0.5rem 1.25rem !important;
    font-size: 0.85rem !important;
  }

  /* Stats */
  .dash-stats {
    padding: 2rem 0;
    border-bottom: 1px solid var(--grace-border);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .stat-card {
    background: var(--grace-surface);
    border: 1px solid var(--grace-border);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: var(--grace-purple);
    line-height: 1.2;
  }

  .stat-label {
    display: block;
    font-size: 0.8rem;
    color: var(--grace-text-muted);
    margin-top: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  /* Body Grid */
  .dash-body {
    padding: 2rem 0 4rem;
  }

  .dash-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 2rem;
    align-items: start;
  }

  .dash-panel-title {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--grace-text-secondary);
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--grace-border);
  }

  /* Activity Feed */
  .dash-panel {
    background: var(--grace-surface);
    border: 1px solid var(--grace-border);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .activity-feed {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .activity-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--grace-border);
  }

  .activity-item:last-child {
    border-bottom: none;
  }

  .activity-icon {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .activity-icon-chat { background: var(--grace-purple); }
  .activity-icon-signup { background: var(--grace-gold); }
  .activity-icon-workstream_join { background: #059669; }

  .activity-detail {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex: 1;
  }

  .activity-type {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--grace-text);
  }

  .activity-time {
    font-size: 0.8rem;
    color: var(--grace-text-muted);
  }

  .empty-state {
    color: var(--grace-text-muted);
    font-size: 0.9rem;
    font-style: italic;
    padding: 1rem 0;
  }

  /* Sidebar */
  .dash-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .profile-card,
  .actions-card,
  .history-card {
    background: var(--grace-surface);
    border: 1px solid var(--grace-border);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .profile-fields {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .profile-field {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .profile-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--grace-text-muted);
  }

  .profile-value {
    font-size: 0.9rem;
    color: var(--grace-text);
  }

  .profile-statement {
    font-style: italic;
    color: var(--grace-text-secondary);
  }

  /* Quick Actions */
  .quick-actions {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .quick-action {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border: none;
    background: none;
    color: var(--grace-text);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    border-bottom: 1px solid var(--grace-border);
    transition: color var(--transition-base);
    width: 100%;
    text-align: left;
  }

  .quick-action:last-child {
    border-bottom: none;
  }

  .quick-action:hover {
    color: var(--grace-purple);
  }

  .quick-action svg {
    color: var(--grace-text-muted);
    flex-shrink: 0;
    transition: color var(--transition-base);
  }

  .quick-action:hover svg {
    color: var(--grace-purple);
  }

  /* Chat History */
  .chat-history {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .history-item {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--grace-border);
  }

  .history-item:last-child {
    border-bottom: none;
  }

  .history-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .history-date {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--grace-text);
  }

  .history-count {
    font-size: 0.75rem;
    color: var(--grace-text-muted);
  }

  .history-summary {
    font-size: 0.8rem;
    color: var(--grace-text-secondary);
    margin-top: 0.25rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .dash-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .stats-grid {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .stat-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      text-align: left;
      padding: 1rem 1.25rem;
    }

    .stat-number {
      font-size: 1.5rem;
      order: 2;
    }

    .stat-label {
      order: 1;
      margin-top: 0;
    }

    .dash-header-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
